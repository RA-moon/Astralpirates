{
  "name": "astralpirates-monorepo",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "frontend",
    "cms",
    "shared",
    "eslint-plugin-astral-design"
  ],
  "scripts": {
    "artifacts:refresh": "pnpm -w plan:status && node scripts/generate-navigation.mjs && pnpm exec tsx scripts/tools/generate-navigation-docs.mjs && pnpm docs:lint",
    "clean": "bash scripts/clean.sh",
    "prelint": "pnpm run build:shared",
    "lint": "pnpm run lint:all",
    "lint:all": "pnpm tokens:check && pnpm tokens:usage:check && pnpm size:ssot:check && pnpm run lint:frontend && pnpm run lint:cms && pnpm run lint:shared && pnpm run lint:content && pnpm run lint:authorization",
    "lint:frontend": "NODE_ENV=test pnpm --dir frontend lint",
    "lint:cms": "NODE_ENV=test pnpm --dir cms lint",
    "lint:shared": "pnpm --filter \"@astralpirates/shared\" run lint",
    "lint:content": "node scripts/lint-seed-headlines.mjs",
    "lint:authorization": "node scripts/check-authorization-role-checks.mjs",
    "pretest": "pnpm run build:shared",
    "test": "pnpm run test:all",
    "test:all": "pnpm run test:frontend && pnpm run test:cms && pnpm run test:shared",
    "test:frontend": "NODE_ENV=test pnpm --dir frontend test",
    "test:cms": "NODE_ENV=test pnpm --dir cms test",
    "test:shared": "pnpm --filter \"@astralpirates/shared\" run test",
    "build": "pnpm run build:all",
    "build:all": "pnpm run build:shared && pnpm run build:cms && pnpm run build:frontend",
    "build:shared": "pnpm --filter \"@astralpirates/shared\" run build",
    "build:cms": "NODE_ENV=production pnpm --dir cms build",
    "build:frontend": "NODE_ENV=production bash scripts/run-frontend-generate.sh",
    "docker:up": "docker compose up -d frontend cms db neo4j",
    "docker:down": "docker compose down",
    "docker:test": "bash scripts/docker-test.sh",
    "docker:e2e": "RUN_E2E=1 bash scripts/docker-test.sh",
    "test:e2e:design-system": "pnpm --dir frontend test:e2e -- --project chromium --headed --grep 'Design system'",
    "check:api": "node scripts/check-astral-api.mjs",
    "docs:lint": "node --test scripts/lint-docs-integrity.test.mjs && node scripts/lint-docs-integrity.mjs && pnpm exec tsx scripts/tools/generate-navigation-docs.mjs --check && node scripts/validate-structure.mjs && node scripts/audit-tier1-tier2-governance.mjs --assert-clean && node --test scripts/audit-tier1-tier2-governance.test.mjs",
    "plan:status": "pnpm exec tsx scripts/build-plan-status.ts && pnpm run changelog:build",
    "plan:status:cms": "PLAN_SYNC_FROM_CMS=1 pnpm run plan:status",
    "plan:export": "PLAN_EXPORT=1 pnpm run plan:status",
    "changelog:build": "pnpm exec tsx scripts/build-changelog.ts",
    "deploy:preflight": "bash scripts/ci/local-deploy-preflight.sh --docker-test --playwright-e2e",
    "deploy:trigger": "node scripts/ci/trigger-ci-deploy.mjs",
    "deploy:trigger:fast": "node scripts/ci/trigger-ci-deploy.mjs --workflow deploy-fast.yml",
    "env:sync:cms-local": "bash scripts/ops/sync-local-cms-env.sh",
    "env:sync:cms-local:check": "bash scripts/ops/sync-local-cms-env.sh --check",
    "plan:sync": "pnpm exec tsx scripts/sync-plans-from-cms.ts",
    "ops:prune-live-logs": "node scripts/ops/prune-live-logs.mjs",
    "ops:check-cms-auth-drift": "node scripts/ops/check-cms-auth-drift.mjs",
    "ops:check-secret-ssot": "node scripts/ops/check-secret-ssot-parity.mjs",
    "ops:rotate-secrets": "node scripts/ops/rotate-secrets.mjs",
    "cms:seed": "bash scripts/cms-seed.sh",
    "cms:db-check:docker": "docker compose run --rm cms bash -lc \"set -e; /workspace/docker/scripts/bootstrap-node-modules.sh; CI=true pnpm install --frozen-lockfile; pnpm db:check:local\"",
    "cms:access-backfill:docker": "docker compose run --rm cms bash -lc \"set -e; /workspace/docker/scripts/bootstrap-node-modules.sh; CI=true pnpm install --frozen-lockfile; pnpm access:backfill:local\"",
    "cms:access-backfill:docker:with-migrate": "docker compose run --rm cms bash -lc \"set -e; /workspace/docker/scripts/bootstrap-node-modules.sh; CI=true pnpm install --frozen-lockfile; pnpm exec drizzle-kit push --force --config ./drizzle.config.ts; pnpm payload migrate -- --config ./payload.config.ts; pnpm access:backfill:local\"",
    "cms:expire-invites": "pnpm --filter astralpirates-cms exec tsx ./src/scripts/expireInvites.ts",
    "cms:normalize-logs": "pnpm --filter astralpirates-cms exec tsx ./src/scripts/normalizeLogs.ts",
    "cms:update-log-titles": "pnpm --filter astralpirates-cms exec tsx ./src/scripts/updateLogTitles.ts",
    "check:cms-stack": "node scripts/validate-cms-stack.mjs && node scripts/validate-cms-media-codecs.mjs",
    "check:frontend:chunk-budgets": "node scripts/check-frontend-chunk-budgets.mjs",
    "test:chunk-budgets": "node --test scripts/check-frontend-chunk-budgets.test.mjs",
    "tokens:generate": "pnpm exec tsx scripts/generate-theme-tokens.ts",
    "tokens:check": "pnpm exec tsx scripts/generate-theme-tokens.ts --check",
    "tokens:usage:check": "pnpm exec tsx scripts/check-design-token-usage.ts",
    "size:ssot:check": "pnpm exec tsx scripts/check-size-ssot.ts --assert-no-regression",
    "size:ssot:report": "pnpm exec tsx scripts/check-size-ssot.ts --report",
    "size:ssot:ledger": "pnpm exec tsx scripts/check-size-ssot.ts --write-ledger"
  },
  "dependencies": {
    "@astralpirates/shared": "workspace:*",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "4.1.1",
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "overrides": {
      "ajv@6.12.6": "6.14.0",
      "ajv@8.17.1": "8.18.0",
      "baseline-browser-mapping": "2.10.16",
      "devalue": "5.6.4",
      "defu": "6.1.7",
      "diff@4.0.2": "4.0.4",
      "drizzle-orm": "0.45.2",
      "dompurify": "3.3.2",
      "fast-xml-parser": "5.5.10",
      "file-type": "21.3.2",
      "flatted": "3.4.2",
      "glob@10.4.5": "10.5.0",
      "happy-dom": "20.8.9",
      "immutable": "4.3.8",
      "js-yaml": "4.1.1",
      "lodash": "4.18.1",
      "minimatch@3.1.2": "3.1.4",
      "minimatch@5.1.6": "5.1.8",
      "minimatch@9.0.1": "9.0.7",
      "minimatch@9.0.5": "9.0.7",
      "node-forge": "1.4.0",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "rollup": "4.59.0",
      "serialize-javascript": "7.0.3",
      "simple-git": "3.32.3",
      "srvx": "0.11.15",
      "svgo": "4.0.1",
      "tar": "7.5.11",
      "unhead": "2.1.11",
      "undici": "7.24.4",
      "@esbuild-kit/core-utils>esbuild": "0.25.4"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "@payloadcms/next>next": "15.5.10",
        "@payloadcms/ui>next": "15.5.10",
        "@bomb.sh/tab>citty": "0.2.0"
      }
    }
  },
  "packageManager": "pnpm@10.20.0+sha512.cf9998222162dd85864d0a8102e7892e7ba4ceadebbf5a31f9c2fce48dfce317a9c53b9f6464d1ef9042cba2e02ae02a9f7c143a2b438cd93c91840f0192b9dd"
}
