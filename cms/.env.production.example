# CMS production/staging env (copy to /opt/astralpirates-cms/.env and fill values)
NODE_ENV=production

PAYLOAD_SECRET=change-me
PAYLOAD_PUBLIC_SERVER_URL=https://cms.astralpirates.com
PAYLOAD_CONFIG_PATH=./payload.config.ts

DATABASE_URL=postgres://astralpirates:strong-password@db-host:5432/astralpirates
NEO4J_URI=bolt://neo4j-host:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# Frontend origin(s) used for CORS/CSRF
FRONTEND_ORIGIN=https://astralpirates.com
REGISTER_LINK_BASE=https://astralpirates.com/enlist/accept

# Media storage (SeaweedFS/S3-compatible)
MEDIA_STORAGE_PROVIDER=seaweedfs
MEDIA_BASE_URL=https://artifact.astralpirates.com
MEDIA_S3_ENDPOINT=https://artifact.astralpirates.com/s3
MEDIA_S3_REGION=us-east-1
MEDIA_S3_FORCE_PATH_STYLE=true
MEDIA_S3_ACCESS_KEY_ID=change-me
MEDIA_S3_SECRET_ACCESS_KEY=change-me
MEDIA_BUCKET_AVATARS=avatars
MEDIA_BUCKET_GALLERY=gallery
MEDIA_BUCKET_TASKS=tasks
MEDIA_BUCKET_BADGES=badges
MEDIA_BUCKET_MATRIX=matrix-media
MEDIA_BUCKET_VIDEOS=videos
MEDIA_BUCKET_MODELS=models
MEDIA_BUCKET_DOCUMENTS=documents
MEDIA_DEFAULT_ACCESS=public
MEDIA_DEFAULT_LIFECYCLE=durable
MEDIA_DEFAULT_RETENTION_POLICY=rp-forever
MEDIA_SIGNED_URL_TTL_SECONDS=300
MEDIA_ENFORCE_SCAN=true
MEDIA_REQUIRE_QUARANTINE=true
MEDIA_MAX_UPLOAD_AVATAR_BYTES=2097152
MEDIA_MAX_UPLOAD_GALLERY_BYTES=26214400
MEDIA_MAX_UPLOAD_TASK_BYTES=26214400
MEDIA_MAX_UPLOAD_BADGE_BYTES=2097152
MEDIA_QUOTA_USER_DAILY_BYTES=209715200
MEDIA_QUOTA_FLIGHTPLAN_BYTES=2147483648

# SMTP settings (required for invites/password resets)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASSWORD=change-me
EMAIL_FROM_NAME=Astral Pirates
EMAIL_FROM_ADDRESS=dispatch@astralpirates.com
