{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "types": [
      "node",
      "next",
      "vitest/globals"
    ],
    "baseUrl": ".",
    "paths": {
      "@payload-config": [
        "./payload.config.ts"
      ],
      "@payload-config/*": [
        "./*"
      ],
      "@/*": [
        "./*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "debug.ts",
    "next-env.d.ts",
    "payload.config.ts",
    "src/**/*.ts",
    "types/**/*.d.ts",
    ".next-dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "src/payload-generated-schema.ts",
    "src/scripts/**"
  ]
}
