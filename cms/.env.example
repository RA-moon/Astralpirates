# Core Payload secrets
PAYLOAD_SECRET=changeme
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Database connections
DATABASE_URL=postgres://astral:astral@localhost:5432/astralpirates
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
REDIS_URL=redis://localhost:6379/0

# Media storage (SeaweedFS/S3-compatible)
MEDIA_STORAGE_PROVIDER=local
MEDIA_BASE_URL=http://localhost:3000/media
MEDIA_S3_ENDPOINT=http://localhost:8333
MEDIA_S3_REGION=us-east-1
MEDIA_S3_FORCE_PATH_STYLE=true
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
MEDIA_BUCKET_AVATARS=avatars
MEDIA_BUCKET_GALLERY=gallery
MEDIA_BUCKET_TASKS=tasks
MEDIA_BUCKET_BADGES=badges
MEDIA_BUCKET_MATRIX=matrix-media
MEDIA_BUCKET_VIDEOS=videos
MEDIA_BUCKET_MODELS=models
MEDIA_BUCKET_DOCUMENTS=documents
MEDIA_DEFAULT_ACCESS=public
MEDIA_DEFAULT_LIFECYCLE=durable
MEDIA_DEFAULT_RETENTION_POLICY=rp-forever
MEDIA_SIGNED_URL_TTL_SECONDS=300
MEDIA_ENFORCE_SCAN=true
MEDIA_REQUIRE_QUARANTINE=true
MEDIA_MAX_UPLOAD_AVATAR_BYTES=2097152
MEDIA_MAX_UPLOAD_GALLERY_BYTES=26214400
MEDIA_MAX_UPLOAD_TASK_BYTES=26214400
MEDIA_MAX_UPLOAD_BADGE_BYTES=2097152
MEDIA_QUOTA_USER_DAILY_BYTES=209715200
MEDIA_QUOTA_FLIGHTPLAN_BYTES=2147483648

# Registration & password flows
REGISTER_LINK_BASE=http://localhost:3000/enlist/accept
FORGOT_PASSWORD_URL=http://localhost:8000/reset-password
REGISTRATION_TOKEN_TTL=172800000
REGISTRATION_INVITE_LIMIT=3
REGISTRATION_INVITE_IP_ALLOWLIST=

# Email delivery (leave SMTP_* empty to log emails to stdout)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_IGNORE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_NAME=
# Optional alias for SMTP_PASSWORD if your provider uses PASS naming
# SMTP_PASS=
EMAIL_FROM_NAME=Astralpirates
EMAIL_FROM_ADDRESS=noreply@astralpirates.com

# Session configuration (seconds)
PAYLOAD_SESSION_IDLE_TIMEOUT=3600
