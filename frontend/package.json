{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "predev": "node ../scripts/check-astral-api.mjs --warn-only",
    "build": "nuxt build",
    "pregenerate": "pnpm -w plan:status",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "postgenerate": "node ../scripts/ensure-frontend-index.mjs && node ../scripts/validate-frontend-api-base.mjs",
    "preview": "nuxt preview",
    "prepreview": "node ../scripts/check-astral-api.mjs",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "pnpm exec vue-tsc --noEmit -p tsconfig.json",
    "pretest": "NUXT_VALIDATE_PROD=false nuxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "postinstall": "NUXT_VALIDATE_PROD=false nuxt prepare"
  },
  "dependencies": {
    "@astralpirates/shared": "workspace:*",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.0.0",
    "h3": "^1.15.11",
    "nuxt": "^4.4.2",
    "ofetch": "^1.4.1",
    "pinia": "^3.0.4",
    "three": "^0.160.0",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@nuxt/eslint-config": "^1.15.2",
    "@playwright/test": "1.56.1",
    "@testing-library/vue": "^8.0.4",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.2",
    "eslint-plugin-astral-design": "workspace:*",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.1.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.0.8",
    "msw": "^2.6.4",
    "postcss-custom-media": "^11.0.6",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.3",
    "vue-tsc": "3.2.6"
  }
}
